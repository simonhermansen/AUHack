# Python cache and environments
__pycache__/
*.py[cod]
.venv/

# Frontend dependencies/build outputs
**/node_modules/
**/dist/

# Secrets
.env
.env.*
!.env.example
.streamlit/secrets.toml

# OS/editor files
.DS_Store
.vscode/

# Large generated training logs
catboost_info/

# Optional generated artifacts
artifacts/**/*.csv
artifacts/**/*.parquet
artifacts/**/*.png
artifacts/**/*.cbm

# Runtime assets that should stay in git for plug-and-play judging
!artifacts/core/catboost_price_model.cbm
!artifacts/core/panel_dataset.parquet
!artifacts/core/metrics.csv
!artifacts/core/feature_importance.csv

# Keep production builds so Streamlit can embed games without local npm build
!/energy-gambling-markets/dist/
!/energy-gambling-markets/dist/**
!/grid-casino/dist/
!/grid-casino/dist/**
